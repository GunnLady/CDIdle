{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "board": "node workboard/server/server.mjs",
    "board:start": "powershell -NoProfile -ExecutionPolicy Bypass -File workboard/scripts/start.ps1",
    "board:stop": "powershell -NoProfile -ExecutionPolicy Bypass -File workboard/scripts/stop.ps1",
    "board:validate": "node workboard/scripts/validate.mjs",
    "board:sync": "node workboard/scripts/sync-github.mjs",
    "board:sync:apply": "node workboard/scripts/sync-github.mjs --apply",
    "supabase:verify": "node supabase/verify-local.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "clean": "rm -rf dist server.js",
    "check": "npm run board:validate && npm run typecheck && npm run lint && npm test -- --run && npm run build"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "firebase": "^12.15.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.14.0",
    "@vitest/coverage-v8": "^4.1.10",
    "autoprefixer": "^10.4.21",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.64.0",
    "vite": "^6.2.3",
    "vitest": "^4.1.10"
  }
}
