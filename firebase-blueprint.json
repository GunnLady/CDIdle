{
  "collections": {
    "users": {
      "rules": "request.auth != null && request.auth.uid == userId",
      "fields": {
        "uid": "string",
        "email": "string",
        "createdAt": "timestamp",
        "updatedAt": "timestamp"
      },
      "subcollections": {
        "savegame": {
          "rules": "request.auth != null && request.auth.uid == userId",
          "fields": {
            "resources": "map",
            "buildings": "map",
            "citizens": "map",
            "totalCitizensCount": "number",
            "districts": "map",
            "heroes": "array",
            "activeDungeonFloor": "number",
            "activeDungeonRoom": "number",
            "highestFloorReached": "number",
            "inventory": "array",
            "updatedAt": "timestamp"
          }
        }
      }
    }
  }
}
