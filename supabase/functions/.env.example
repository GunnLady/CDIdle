# Variables chargees par `supabase functions serve --env-file`.
# Les alias GAME_API_* evitent le rejet des noms reserves SUPABASE_* par la CLI.
GAME_API_SUPABASE_URL=http://127.0.0.1:54321
GAME_API_SERVICE_ROLE_KEY=
GAME_API_JWT_SECRET=
GAME_API_EXPECTED_ISSUER=http://127.0.0.1:54321/auth/v1
GAME_API_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# Local uniquement. Ne jamais activer sur un environnement partage ou de production.
GAME_API_ENABLE_CHEATS=false
